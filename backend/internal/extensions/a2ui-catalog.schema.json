{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer5/a2ui-catalog-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "policy_mode", "catalog_id", "catalog_version", "schema_version", "components"],
  "properties": {
    "version": {"const": 2},
    "policy_mode": {"const": "fail_closed"},
    "catalog_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$"},
    "catalog_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"},
    "components": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "allowed_props", "allows_children"],
        "properties": {
          "type": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]{0,63}$"},
          "allowed_props": {
            "type": "array",
            "maxItems": 64,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z][a-zA-Z0-9_]{0,63}$"}
          },
          "required_props": {
            "type": "array",
            "maxItems": 32,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z][a-zA-Z0-9_]{0,63}$"}
          },
          "allows_children": {"type": "boolean"},
          "max_children": {"type": "integer", "minimum": 0, "maximum": 100}
        }
      }
    }
  }
}
