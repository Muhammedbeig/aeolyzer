{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer5/a2ui-frame-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["frame_id", "surface", "catalog_id", "catalog_version", "schema_version", "root_id", "nodes", "signature"],
  "properties": {
    "frame_id": {"$ref": "#/$defs/id"},
    "trace_id": {"$ref": "#/$defs/id"},
    "surface": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$"},
    "catalog_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$"},
    "catalog_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"},
    "root_id": {"$ref": "#/$defs/id"},
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {"$ref": "#/$defs/node"}
    },
    "fallback_text": {"type": "string", "maxLength": 8000},
    "expires_at": {"type": "string", "format": "date-time"},
    "signature": {"type": "string", "minLength": 43, "maxLength": 256}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,127}$"},
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]{0,63}$"},
        "props": {"type": "object", "maxProperties": 64},
        "children": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/id"}
        },
        "slot": {"type": "string", "maxLength": 64}
      }
    }
  }
}
