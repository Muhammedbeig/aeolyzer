{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer5/approval-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["approval_id", "risk_level", "requires_mfa", "summary", "change_type", "risk_notes", "expires_at"],
  "properties": {
    "approval_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "risk_level": {"enum": ["low", "medium", "high", "critical"]},
    "requires_mfa": {"type": "boolean"},
    "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "change_type": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$"},
    "before": {},
    "after": {},
    "risk_notes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {"type": "string", "minLength": 1, "maxLength": 500}
    },
    "expires_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {"properties": {"risk_level": {"enum": ["high", "critical"]}}},
      "then": {"properties": {"requires_mfa": {"const": true}}}
    }
  ]
}
