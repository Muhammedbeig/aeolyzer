{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer5/surface-patch-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["patch_id", "surface", "base_revision_hash", "operations", "fallback_text"],
  "properties": {
    "patch_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "surface": {"enum": ["canvas", "brief", "seo_settings"]},
    "base_revision_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op", "path"],
        "properties": {
          "op": {"enum": ["add", "replace", "remove"]},
          "path": {"type": "string", "pattern": "^/[A-Za-z0-9_/-]{1,255}$"},
          "value": {}
        },
        "allOf": [
          {
            "if": {"properties": {"op": {"enum": ["add", "replace"]}}},
            "then": {"required": ["value"]}
          }
        ]
      }
    },
    "fallback_text": {"type": "string", "minLength": 1, "maxLength": 8000}
  }
}
