{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer5/ui-event-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["frame_id", "action_id", "interaction_id", "surface_version", "idempotency_key", "expires_at", "signature"],
  "properties": {
    "frame_id": {"$ref": "#/$defs/id"},
    "action_id": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,127}$"},
    "interaction_id": {"$ref": "#/$defs/id"},
    "surface_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"},
    "idempotency_key": {"$ref": "#/$defs/id"},
    "expires_at": {"type": "string", "format": "date-time"},
    "payload": {"type": "object", "maxProperties": 32},
    "signature": {"type": "string", "minLength": 43, "maxLength": 256}
  },
  "$defs": {
    "id": {"type": "string", "minLength": 1, "maxLength": 128}
  }
}
