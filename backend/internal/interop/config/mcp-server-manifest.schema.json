{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer7/mcp-server-manifest-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "server_id", "protocol_versions", "transport", "identity", "capabilities", "tools", "manifest_signature"],
  "properties": {
    "version": {"const": 2},
    "server_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,63}$"},
    "protocol_versions": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 32}},
    "transport": {"enum": ["stdio", "streamable_http"]},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spiffe_id", "mtls_required"],
      "properties": {
        "spiffe_id": {"type": "string", "format": "uri", "pattern": "^spiffe://"},
        "mtls_required": {"const": true}
      }
    },
    "capabilities": {"type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": {"enum": ["tools", "resources", "prompts", "logging"]}},
    "tools": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "input_schema_hash", "output_schema_hash", "action_class", "read_only"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{1,127}$"},
          "input_schema_hash": {"$ref": "#/$defs/hash"},
          "output_schema_hash": {"$ref": "#/$defs/hash"},
          "action_class": {"type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$"},
          "read_only": {"type": "boolean"}
        }
      }
    },
    "manifest_signature": {"type": "string", "minLength": 64, "maxLength": 512}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  }
}
