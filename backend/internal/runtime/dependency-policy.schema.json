{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer6/dependency-policy-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "policy_mode", "dynamic_install", "dependencies"],
  "properties": {
    "version": {"const": 2},
    "policy_mode": {"const": "fail_closed"},
    "dynamic_install": {"const": false},
    "dependencies": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ecosystem", "name", "version", "digest", "registry"],
        "properties": {
          "ecosystem": {"enum": ["go", "npm", "python", "rust", "system"]},
          "name": {"type": "string", "pattern": "^[A-Za-z0-9@._+-]{1,128}$"},
          "version": {"type": "string", "minLength": 1, "maxLength": 128},
          "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "registry": {"type": "string", "format": "uri", "pattern": "^https://"}
        }
      }
    }
  }
}
