{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer6/egress-policy-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "policy_mode", "default_access", "allowed_domains", "allowed_methods", "allowed_request_headers", "allow_http", "max_request_bytes", "max_response_bytes", "timeout_ms"],
  "properties": {
    "version": {"const": 2},
    "policy_mode": {"const": "fail_closed"},
    "default_access": {"const": "deny"},
    "allowed_domains": {"type": "array", "minItems": 1, "maxItems": 1000, "uniqueItems": true, "items": {"type": "string", "pattern": "^(\\*\\.)?[A-Za-z0-9.-]+$"}},
    "allowed_methods": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["GET", "HEAD", "POST"]}},
    "allowed_request_headers": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9-]{1,64}$"}},
    "allow_http": {"type": "boolean"},
    "max_request_bytes": {"type": "integer", "minimum": 0, "maximum": 4194304},
    "max_response_bytes": {"type": "integer", "minimum": 1, "maximum": 33554432},
    "timeout_ms": {"type": "integer", "minimum": 1000, "maximum": 120000}
  }
}
