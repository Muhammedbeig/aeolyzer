{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer6/jit-token-v2.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["reference_id", "trace_id", "tenant_id", "connector_id", "audience", "scopes", "issued_at", "expires_at", "policy_decision_id"],
  "properties": {
    "reference_id": {"$ref": "#/$defs/id"},
    "trace_id": {"$ref": "#/$defs/id"},
    "tenant_id": {"$ref": "#/$defs/id"},
    "connector_id": {"$ref": "#/$defs/id"},
    "audience": {"type": "string", "format": "uri"},
    "scopes": {"type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_.:-]{0,127}$"}},
    "issued_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "policy_decision_id": {"$ref": "#/$defs/id"}
  },
  "$defs": {"id": {"type": "string", "minLength": 1, "maxLength": 128}}
}
