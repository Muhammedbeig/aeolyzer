{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer4/resource-manifest-v1.json",
  "title": "AEOlyzer skill resource manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "skill_id", "resources"],
  "properties": {
    "version": {
      "const": 1
    },
    "skill_id": {
      "$ref": "#/$defs/identifier"
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["references", "assets", "scripts"],
      "properties": {
        "references": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "assets": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/asset"
          }
        },
        "scripts": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/script"
          }
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(references|assets|scripts)/[A-Za-z0-9][A-Za-z0-9._/-]*$",
      "not": {
        "pattern": "(^|/)\\.\\.(/|$)"
      }
    },
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "loadPolicy": {
      "enum": [
        "never_runtime",
        "on_explicit_reference",
        "on_output_contract_match",
        "on_eval_only",
        "on_layer8_eval_request",
        "on_layer6_execution_request"
      ]
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "load_policy",
        "max_tokens",
        "checksum",
        "contains_sensitive_data"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "load_policy": {
          "$ref": "#/$defs/loadPolicy"
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2500
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "contains_sensitive_data": {
          "const": false
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "load_policy",
        "max_tokens",
        "checksum",
        "contains_ui_schema"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "load_policy": {
          "$ref": "#/$defs/loadPolicy"
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2500
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "contains_ui_schema": {
          "const": false
        }
      }
    },
    "script": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "language",
        "execution_owner_layer",
        "execution_policy",
        "network_access",
        "filesystem_access",
        "max_runtime_seconds",
        "checksum",
        "interface"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "language": {
          "enum": ["go", "python", "shell"]
        },
        "execution_owner_layer": {
          "const": "layer_6_runtime"
        },
        "execution_policy": {
          "const": "requires_layer2_authorization"
        },
        "network_access": {
          "const": false
        },
        "filesystem_access": {
          "enum": ["none", "stdin_stdout_only", "declared_read_only"]
        },
        "max_runtime_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "interface": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input_contract", "output_contract"],
          "properties": {
            "input_contract": {
              "$ref": "#/$defs/identifier"
            },
            "output_contract": {
              "$ref": "#/$defs/identifier"
            }
          }
        }
      }
    }
  }
}
