{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeolyzer.local/schemas/layer4/skill-frontmatter-v2.json",
  "title": "AEOlyzer SKILL.md frontmatter v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "description",
    "version",
    "owner_team",
    "tier",
    "risk_class",
    "compatible_profiles",
    "compatible_intents",
    "allowed_modes",
    "capability_tags",
    "declared_action_classes",
    "output_contracts",
    "token_budget",
    "resource_manifest",
    "eval_manifest"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,63}$"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 720
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "owner_team": {
      "$ref": "#/$defs/identifier"
    },
    "tier": {
      "enum": ["read", "draft", "act"]
    },
    "risk_class": {
      "enum": ["low", "medium", "high", "critical"]
    },
    "compatible_profiles": {
      "$ref": "#/$defs/identifierList"
    },
    "compatible_intents": {
      "$ref": "#/$defs/identifierList"
    },
    "allowed_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["plan", "read", "write", "edit", "optimize", "audit"]
      }
    },
    "capability_tags": {
      "$ref": "#/$defs/identifierList"
    },
    "declared_action_classes": {
      "$ref": "#/$defs/identifierList"
    },
    "output_contracts": {
      "$ref": "#/$defs/identifierList"
    },
    "token_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "body_max_tokens",
        "references_max_tokens",
        "assets_max_tokens",
        "total_active_max_tokens"
      ],
      "properties": {
        "body_max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3000
        },
        "references_max_tokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2500
        },
        "assets_max_tokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2500
        },
        "total_active_max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9000
        }
      }
    },
    "resource_manifest": {
      "const": "resource-manifest.yaml"
    },
    "eval_manifest": {
      "const": "eval-manifest.yaml"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "identifierList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    }
  }
}
